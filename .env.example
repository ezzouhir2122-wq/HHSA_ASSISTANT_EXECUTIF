# Copy this file to .env and fill in your values
# Never commit .env to git

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# Firecrawl (web scraping)
FIRECRAWL_API_KEY=

# Google OAuth 2.0 — for Google Sheets write access
# Create credentials at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client (Desktop app)
# Get GOOGLE_REFRESH_TOKEN via a one-time OAuth flow (Google OAuth Playground or local script)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Sheets target
# GOOGLE_SHEETS_ID: the long ID in the spreadsheet URL
# GOOGLE_SHEETS_RANGE: tab name + column range, e.g. "Dubai HR Leads!A:Q"
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=
